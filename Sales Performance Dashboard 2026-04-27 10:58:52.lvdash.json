                "x": {
                  "fieldName": "order_date",
                  "displayName": "Order Date",
                  "scale": {
                    "type": "temporal"
                  }
                },
                "y": {
                  "fieldName": "measure(count)",
                  "format": {
                    "type": "number-plain",
                    "decimalPlaces": {
                      "type": "exact",
                      "places": 0
                    },
                    "abbreviation": "compact"
                  },
                  "displayName": "Order Count",
                  "scale": {
                    "type": "quantitative"
                  }
                }
              }
            }
          },
          "position": {
            "x": 2,
            "y": 2,
            "width": 6,
            "height": 6
          }
        }
      ],
      "pageType": "PAGE_TYPE_CANVAS",
      "layoutVersion": "GRID_V1"
    },
